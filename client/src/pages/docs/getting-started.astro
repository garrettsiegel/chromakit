---
import DocsLayout from '@/layouts/DocsLayout.astro';
import DocSection from '@/components/docs/DocSection.astro';
import StaticCode from '@/components/docs/StaticCode.astro';
import { BasicDemoCard } from '@/components/demos/BasicDemoCard';
import { DOCS_NAV } from './_nav';
import {
  installCode,
  nextAppCode,
  nextPagesCode,
  viteCode,
  oklchCode,
} from '@/site-data/getting-started-snippets';

const meta = DOCS_NAV.find((d) => d.slug === 'getting-started');
const description = meta?.description ?? '';

const BROWSERS = [
  ['Chrome / Edge', '88+'],
  ['Firefox', '87+'],
  ['Safari', '15+'],
  ['Node.js (SSR / build)', '20+'],
];
---

<DocsLayout
  slug="getting-started"
  title="Getting Started · ChromaKit Docs"
  description={description}
>
  <div class="space-y-3">
    <h1 class="text-4xl font-bold tracking-tight">Getting Started</h1>
    <p class="text-lg text-muted-foreground">
      ChromaKit is a zero-dependency React color picker with first-class support
      for OKLCH, OKLAB, and every traditional color space. Install it, import
      the stylesheet, and render.
    </p>
  </div>

  <DocSection
    id="installation"
    title="Installation"
    description="ChromaKit ships as an ES module with bundled TypeScript types."
  >
    <StaticCode code={installCode} lang="bash" />
  </DocSection>

  <DocSection
    id="basic-usage"
    title="Basic usage"
    description="Import the component and its stylesheet, then wire it to state. onChange receives a ColorValue with every format pre-converted."
  >
    <BasicDemoCard client:visible />
  </DocSection>

  <DocSection
    id="framework-setup"
    title="Framework setup"
    description="ChromaKit works in any React app. It renders on the client, so server frameworks need the picker loaded client-side."
  >
    <div class="space-y-6">
      <div class="space-y-2">
        <h3 class="text-lg font-semibold">Next.js App Router</h3>
        <p class="text-sm text-muted-foreground">
          Mark the component with <code>'use client'</code>.
        </p>
        <StaticCode code={nextAppCode} />
      </div>
      <div class="space-y-2">
        <h3 class="text-lg font-semibold">Next.js Pages Router (SSR)</h3>
        <p class="text-sm text-muted-foreground">
          Load it dynamically with <code>ssr: false</code>.
        </p>
        <StaticCode code={nextPagesCode} />
      </div>
      <div class="space-y-2">
        <h3 class="text-lg font-semibold">Vite / Create React App</h3>
        <p class="text-sm text-muted-foreground">Works out of the box.</p>
        <StaticCode code={viteCode} />
      </div>
    </div>
  </DocSection>

  <DocSection
    id="why-oklch"
    title="Why OKLCH?"
    description="OKLCH is perceptually uniform — equal numeric changes produce equal visual differences, which HSL cannot promise."
  >
    <ul class="list-disc space-y-1.5 pl-5 text-sm text-muted-foreground">
      <li>
        <strong class="text-foreground">Predictable lightness</strong> — a given
        L looks equally bright at every hue.
      </li>
      <li>
        <strong class="text-foreground">Smoother gradients</strong> — no muddy
        middle tones between two colors.
      </li>
      <li>
        <strong class="text-foreground">Consistent scales</strong> — generate
        tonal palettes with uniform visual weight.
      </li>
      <li>
        <strong class="text-foreground">Wider gamut</strong> — reach more vivid
        colors on modern displays.
      </li>
    </ul>
    <StaticCode code={oklchCode} lang="tsx" />
  </DocSection>

  <DocSection
    id="browser-support"
    title="Browser support"
    description="ChromaKit runs everywhere modern React runs. CSS oklch() output is only needed by your app if you render the string — the picker computes OKLCH in JS regardless."
  >
    <div class="overflow-x-auto rounded-lg border border-border">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr class="bg-muted/50 text-left">
            <th class="px-4 py-2.5 font-semibold">Environment</th>
            <th class="px-4 py-2.5 font-semibold">Minimum version</th>
          </tr>
        </thead>
        <tbody>
          {
            BROWSERS.map(([name, version]) => (
              <tr class="border-t border-border">
                <td class="px-4 py-2.5">{name}</td>
                <td class="px-4 py-2.5 text-muted-foreground">{version}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </DocSection>
</DocsLayout>
