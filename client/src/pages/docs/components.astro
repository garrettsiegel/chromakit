---
import DocsLayout from '@/layouts/DocsLayout.astro';
import DocSection from '@/components/docs/DocSection.astro';
import PropsTable from '@/components/docs/PropsTable.astro';
import { BuildYourOwnDemoCard } from '@/components/demos/BuildYourOwnDemoCard';
import { DOCS_NAV } from './_nav';
import { componentGroups } from '@/site-data/components-data';

const meta = DOCS_NAV.find((d) => d.slug === 'components');
const description = meta?.description ?? '';
---

<DocsLayout
  slug="components"
  title="Composable Components · ChromaKit Docs"
  description={description}
>
  <div class="space-y-3">
    <h1 class="text-4xl font-bold tracking-tight">Composable Components</h1>
    <p class="text-lg text-muted-foreground">
      Prefer full control over layout? Drop the wrapper and assemble the
      primitives yourself. They all share one state object from
      <code>useColorState</code>, so wiring them together is trivial.
    </p>
  </div>

  <DocSection
    id="build-your-own"
    title="Build your own picker"
    description="The color area, sliders, inputs, and preview below are all separate exports composed by hand around a single useColorState hook."
  >
    <BuildYourOwnDemoCard client:visible />
  </DocSection>

  {
    componentGroups.map((group) => (
      <DocSection
        id={group.id}
        title={group.title}
        description={group.description}
      >
        <div class="space-y-8">
          {group.components.map((component) => (
            <div class="space-y-3">
              <div class="space-y-1">
                <h3 class="font-mono text-base font-semibold text-primary">
                  {component.name}
                </h3>
                <p class="text-sm text-muted-foreground">
                  {component.description}
                </p>
              </div>
              <PropsTable rows={component.props} showDefault={false} />
            </div>
          ))}
        </div>
      </DocSection>
    ))
  }
</DocsLayout>
