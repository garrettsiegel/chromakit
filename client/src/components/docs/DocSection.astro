---
interface Props {
  id: string;
  title: string;
  description?: string;
}

const { id, title, description } = Astro.props;
---

<section id={id} class="scroll-mt-24 space-y-6">
  <div class="space-y-2">
    <h2 class="text-2xl font-bold tracking-tight">{title}</h2>
    {
      description && (
        <p class="text-muted-foreground leading-relaxed">{description}</p>
      )
    }
  </div>
  <slot />
</section>
