---
import { Image } from 'astro:assets';
import logo from '@/assets/logo.png';

const sponsorClass =
  'inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium min-h-8 px-3 text-xs border [border-color:var(--button-outline)] shadow-xs border-pink-500/50 hover:border-pink-500 hover:text-pink-500 hover:bg-pink-500/10 transition-colors';
---

<footer class="border-t border-border py-12 bg-muted/30">
  <div class="container mx-auto px-6">
    <div
      class="flex flex-col md:flex-row items-center justify-between gap-6"
    >
      <!-- Logo & Description -->
      <div class="flex items-center gap-3">
        <Image
          src={logo}
          alt="ChromaKit logo"
          width={32}
          height={32}
          densities={[2]}
          loading="eager"
          class="w-8 h-8 rounded-lg"
        />
        <div>
          <div class="font-bold">ChromaKit</div>
          <p class="text-sm text-muted-foreground">
            Modern color picker for React
          </p>
        </div>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm">
        <a
          href="/docs"
          class="text-muted-foreground hover:text-foreground transition-colors font-medium"
          >Documentation</a
        >
        <a
          href="https://github.com/garrettsiegel/chromakit"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground hover:text-foreground transition-colors"
          >GitHub</a
        >
        <a
          href="https://www.npmjs.com/package/chromakit-react"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground hover:text-foreground transition-colors"
          >npm</a
        >
        <a
          href="https://github.com/garrettsiegel/chromakit/blob/main/LICENSE"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground hover:text-foreground transition-colors"
          >MIT License</a
        >
      </div>

      <!-- Social -->
      <div class="flex items-center gap-4">
        <a
          href="https://github.com/garrettsiegel"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground hover:text-foreground transition-colors"
          aria-label="GitHub profile"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"
            ></path>
          </svg>
        </a>
        <a
          href="https://github.com/sponsors/garrettsiegel"
          target="_blank"
          rel="noopener noreferrer"
          class={sponsorClass}
        >
          <svg
            class="w-3.5 h-3.5 fill-current"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
            ></path>
          </svg>
          Sponsor
        </a>
      </div>
    </div>
  </div>
</footer>
