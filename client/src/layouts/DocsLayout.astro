---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SiteHeader from '@/components/layout/SiteHeader.astro';
import SiteFooter from '@/components/layout/SiteFooter.astro';
import { DOCS_NAV } from '@/pages/docs/_nav';

interface Props {
  slug: string;
  title: string;
  description: string;
}

const { slug, title, description } = Astro.props;

const sideLink = (active: boolean) =>
  active
    ? 'block rounded-lg px-3 py-2 text-sm bg-muted font-medium text-foreground'
    : 'block rounded-lg px-3 py-2 text-sm text-muted-foreground hover:bg-muted/50 hover:text-foreground transition-colors';

const pillLink = (active: boolean) =>
  active
    ? 'whitespace-nowrap rounded-full px-3 py-1.5 text-sm bg-primary text-primary-foreground'
    : 'whitespace-nowrap rounded-full px-3 py-1.5 text-sm bg-muted text-muted-foreground';
---

<BaseLayout title={title} description={description}>
  <div class="min-h-screen bg-background">
    <SiteHeader />
    <div class="container mx-auto px-6 py-10">
      <!-- Mobile nav -->
      <nav
        class="md:hidden sticky top-[73px] z-40 -mx-6 mb-6 flex gap-2 overflow-x-auto border-b border-border bg-background/80 px-6 py-3 backdrop-blur-xl"
      >
        {
          DOCS_NAV.map((doc) => (
            <a href={`/docs/${doc.slug}`} class={pillLink(doc.slug === slug)}>
              {doc.title}
            </a>
          ))
        }
      </nav>
      <div class="flex gap-10">
        <aside class="hidden md:block w-56 shrink-0">
          <nav class="sticky top-24 space-y-1">
            <p
              class="px-3 pb-2 text-xs font-semibold uppercase tracking-wide text-muted-foreground"
            >
              Documentation
            </p>
            {
              DOCS_NAV.map((doc) => (
                <a
                  href={`/docs/${doc.slug}`}
                  class={sideLink(doc.slug === slug)}
                >
                  {doc.title}
                </a>
              ))
            }
          </nav>
        </aside>
        <main class="min-w-0 flex-1 max-w-3xl space-y-16 pb-16">
          <slot />
        </main>
      </div>
    </div>
    <SiteFooter />
  </div>
</BaseLayout>
